# Claude API key — used by dev-server.js (api/chat proxy) in real mode
ANTHROPIC_API_KEY=your-key-here

# Design-review / offline mode.
# When true, src/services/claude.ts returns static fixtures from
# src/services/mocks.ts instead of hitting /api/chat. Enables full UI
# walkthrough without running the Express proxy or spending API credits.
VITE_USE_MOCK=false
